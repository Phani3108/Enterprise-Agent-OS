# ─────────────────────────────────────────────────────────────────────────────
# AgentOS — Environment configuration (root)
# Copy to `.env` and fill in values you care about. Every variable is optional:
# when unset, the gateway falls back to a safe simulation/demo mode so you can
# run the full UI without wiring real APIs.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
GATEWAY_PORT=3000
WEB_PORT=3001
# Full public URL of the gateway. Used to build OAuth redirect URIs.
GATEWAY_URL=http://localhost:3000

# When true, seeds a starter scenario into the memory graph on first boot.
SEED_DEMO=true

# ── Auth ─────────────────────────────────────────────────────────────────────
# HMAC secret for signing JWTs. Required in production; optional in dev.
JWT_SECRET=
AUTH_SECRET=

# ── Persistence ──────────────────────────────────────────────────────────────
# Choose one: file-backed JSON (default), in-memory, or Postgres.
# PERSISTENCE=postgres
# POSTGRES_URL=postgres://user:pass@localhost:5432/agentos

# ── LLM providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Default provider to use when the UI does not specify one.
DEFAULT_LLM_PROVIDER=anthropic

# ── Connectors: GitHub ───────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# ── Connectors: Jira ─────────────────────────────────────────────────────────
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# ── Connectors: Slack ────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
# Incoming-webhook URL for execution.completed notifications.
SLACK_WEBHOOK_URL=
# OAuth (only needed if using the /oauth/callback flow)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── Connectors: Google (Drive, GA4) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GA4_PROPERTY_ID=

# ── Connectors: HubSpot ──────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# ── Connectors: LinkedIn Ads ─────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Connectors: Salesforce ───────────────────────────────────────────────────
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_ACCESS_TOKEN=

# ── Connectors: WordPress / Perplexity ───────────────────────────────────────
WORDPRESS_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
PERPLEXITY_API_KEY=

# ── Observability ────────────────────────────────────────────────────────────
# Set to 'true' to enable OpenTelemetry span export.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
