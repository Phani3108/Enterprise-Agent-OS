{
    "name": "@agentos/skills-runtime",
    "version": "0.1.0",
    "private": true,
    "description": "AgentOS Skills Runtime Service — skill lifecycle, compilation, execution, marketplace",
    "license": "MIT",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "dev": "tsx watch src/index.ts",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@agentos/sdk": "workspace:*",
        "@agentos/events": "workspace:*",
        "@agentos/skills": "workspace:*",
        "@agentos/router": "workspace:*"
    },
    "devDependencies": {
        "typescript": "^5.4.0",
        "tsx": "^4.7.0",
        "vitest": "^1.6.0"
    }
}