{
    "graph_id": "marketing.agent_graph",
    "name": "Marketing Agent Collaboration Graph",
    "description": "Self-optimizing agent network where agents collaborate through shared state",
    "nodes": [
        { "id": "research", "agent": "marketing.research", "depends_on": [] },
        { "id": "competitor", "agent": "marketing.competitor", "depends_on": ["research"] },
        { "id": "strategy", "agent": "marketing.strategy", "depends_on": ["research", "competitor"] },
        { "id": "seo", "agent": "marketing.seo", "depends_on": ["research"] },
        { "id": "copy", "agent": "marketing.copy", "depends_on": ["strategy"] },
        { "id": "design", "agent": "marketing.design", "depends_on": ["copy"] },
        { "id": "landing", "agent": "marketing.landing", "depends_on": ["copy", "design"] },
        { "id": "email", "agent": "marketing.email", "depends_on": ["copy"] },
        { "id": "campaign", "agent": "marketing.campaign", "depends_on": ["design", "copy"] },
        { "id": "analytics", "agent": "marketing.analytics", "depends_on": ["campaign"] },
        { "id": "optimization", "agent": "marketing.optimization", "depends_on": ["analytics"] }
    ],
    "feedback_loops": [
        {
            "from": "optimization",
            "to": ["strategy", "copy", "design"],
            "trigger": "performance_below_threshold",
            "description": "When campaign performance drops, optimization agent triggers strategy/copy/design regeneration"
        }
    ],
    "shared_state": {
        "state.market_insights": { "written_by": "research", "read_by": ["strategy", "competitor", "seo"] },
        "state.competitor_analysis": { "written_by": "competitor", "read_by": ["strategy"] },
        "state.strategy": { "written_by": "strategy", "read_by": ["copy", "campaign"] },
        "state.messaging": { "written_by": "copy", "read_by": ["design", "landing", "email", "campaign"] },
        "state.creatives": { "written_by": "design", "read_by": ["campaign", "landing"] },
        "state.landing_page": { "written_by": "landing", "read_by": ["campaign"] },
        "state.campaign": { "written_by": "campaign", "read_by": ["analytics"] },
        "state.analytics": { "written_by": "analytics", "read_by": ["optimization"] },
        "state.optimization_actions": { "written_by": "optimization", "read_by": ["strategy", "copy", "design"] }
    },
    "checkpoints": [
        { "before": "campaign", "type": "approve_messaging" },
        { "before": "campaign", "type": "approve_creatives" },
        { "before": "campaign.launch", "type": "approve_campaign_launch" },
        { "before": "campaign.budget", "type": "approve_budget" },
        { "before": "email.send", "type": "approve_email_send" }
    ],
