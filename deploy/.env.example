# EAOS Environment Configuration
# Copy to .env and fill in values

# --- LLM Providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# --- Infrastructure ---
POSTGRES_PASSWORD=eaos-dev-password
DATABASE_URL=postgresql://eaos:eaos-dev-password@localhost:5432/eaos
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# --- Skills ---
SKILL_SOURCE_URL=https://skills.zeta.tech

# --- Secrets Vault ---
VAULT_ADDR=
VAULT_TOKEN=
AWS_REGION=
AWS_SECRET_MANAGER_PREFIX=eaos/

# --- Connectors ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
GITHUB_TOKEN=
GITHUB_ORG=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
GRAFANA_PASSWORD=admin

# --- Reliability ---
MIN_CONFIDENCE=0.7
HALLUCINATION_THRESHOLD=0.8

# --- Model Router ---
DEFAULT_MODEL=gpt-4o
COST_BUDGET_HOURLY_USD=50
FALLBACK_MODEL=gpt-4o-mini
