{
    "name": "@agentos/events",
    "version": "0.1.0",
    "private": true,
    "description": "Event bus abstraction for AgentOS — publish, subscribe, replay, retry, and idempotency",
    "license": "MIT",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "clean": "rm -rf dist"
    },
    "devDependencies": {
        "typescript": "^5.4.0",
        "vitest": "^1.6.0"
    }
}