{
    "name": "@agentos/scheduler",
    "version": "0.1.0",
    "private": true,
    "description": "Distributed task scheduler — priority, fair-share, deadline, cost-aware algorithms",
    "license": "MIT",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@agentos/sdk": "workspace:*",
        "@agentos/runtime": "workspace:*"
    },
    "devDependencies": {
        "typescript": "^5.4.0",
        "vitest": "^1.6.0"
    }
}