{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://agentos.dev/schemas/tool.schema.json",
    "title": "AgentOS Tool Definition",
    "description": "Schema for defining tools that workers can invoke in AgentOS",
    "type": "object",
    "required": [
        "name",
        "description",
        "input"
    ],
    "properties": {
        "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_.]*$",
            "description": "Unique tool identifier in dot notation (e.g., 'github.pr.comment')",
            "examples": [
                "file.read",
                "file.write",
                "github.pull_request.read",
                "github.pull_request.comment",
                "shell.exec",
                "slack.post",
                "k8s.apply"
            ]
        },
        "description": {
            "type": "string",
            "description": "Human-readable description of what the tool does"
        },
        "category": {
            "type": "string",
            "enum": [
                "filesystem",
                "git",
                "github",
                "shell",
                "http",
                "database",
                "messaging",
                "analytics",
                "deployment",
                "custom"
            ],
            "description": "Tool category for organization"
        },
        "input": {
            "type": "object",
            "description": "JSON Schema for the tool's input parameters",
            "properties": {
                "type": {
                    "type": "string",
                    "const": "object"
                },
                "required": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "properties": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "object",
                        "properties": {
                            "type": {
                                "type": "string"
                            },
                            "description": {
                                "type": "string"
                            },
                            "enum": {
                                "type": "array"
                            },
                            "default": {},
                            "examples": {
                                "type": "array"
                            }
                        }
                    }
                }
            }
        },
        "output": {
            "type": "object",
            "description": "JSON Schema for the tool's output",
            "properties": {
                "type": {
                    "type": "string"
                },
                "properties": {
                    "type": "object"
                }
            }
        },
        "auth": {
            "$ref": "#/definitions/AuthConfig"
        },
        "timeout_ms": {
            "type": "integer",
            "minimum": 100,
            "default": 30000,
            "description": "Default timeout for tool invocation"
        },
        "retry": {
            "type": "object",
            "properties": {
                "max_attempts": {
                    "type": "integer",
                    "minimum": 1,
                    "default": 3
                },
                "retryable_errors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Error codes that should trigger a retry"
                }
            }
        },
        "rate_limit": {
            "type": "object",
            "properties": {
                "max_per_minute": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Maximum invocations per minute"
                },
                "max_per_hour": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Maximum invocations per hour"
                }
            }
        },
        "idempotent": {
            "type": "boolean",
            "default": false,
            "description": "Whether repeated calls with the same input produce the same effect"
        },
        "side_effects": {
            "type": "boolean",
            "default": true,
            "description": "Whether the tool modifies external state"
        }
    },
    "definitions": {
        "AuthConfig": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "none",
                        "api_key",
                        "oauth2",
                        "jwt",
                        "basic"
                    ],
                    "description": "Authentication method"
                },
                "secret_ref": {
                    "type": "string",
                    "description": "Reference to secret in vault (e.g., 'vault://github/api-token')"
                },
                "scopes": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Required OAuth2 scopes"
                }
            }
        }
    }
}