{
    "name": "@agentos/db",
    "version": "0.1.0",
    "private": true,
    "description": "Database persistence layer — in-memory dev store + Postgres migrations",
    "license": "MIT",
    "type": "module",
    "main": "dist/connection.js",
    "exports": {
        ".": {
            "types": "./dist/connection.d.ts",
            "import": "./dist/connection.js"
        },
        "./persistent-store": {
            "types": "./dist/persistent-store.d.ts",
            "import": "./dist/persistent-store.js"
        },
        "./postgres-store": {
            "types": "./dist/postgres-store.d.ts",
            "import": "./dist/postgres-store.js"
        },
        "./unified-types": {
            "types": "./dist/unified-types.d.ts",
            "import": "./dist/unified-types.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "migrate": "psql -d eaos -f migrations/001_initial.sql"
    },
    "devDependencies": {
        "typescript": "^5.4.0",
        "@types/pg": "^8.11.0"
    },
    "dependencies": {
        "pg": "^8.13.0"
    }
}