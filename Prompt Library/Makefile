# Short Aliases
# ==============================================================================

# Compose Aliases (short: c)
c: compose-deploy
c-logs: compose-logs
c-clean: compose-clean
c-status: compose-status

# Helm Aliases (short: h)
h: helm-deploy
h-logs: helm-logs
h-clean: helm-clean
h-status: helm
h-pf:     helm-port-forward