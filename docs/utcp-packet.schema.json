{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentos.dev/schemas/utcp-packet-v0.1.json",
  "title": "UTCP Packet",
  "description": "Universal Task Context Protocol packet — end-to-end envelope for one unit of agent work.",
  "type": "object",
  "required": [
    "task_id",
    "workflow_id",
    "version",
    "function",
    "stage",
    "intent",
    "initiator",
    "actors",
    "objectives",
    "constraints",
    "success_criteria",
    "source_artifacts",
    "tool_scopes",
    "context",
    "privacy_level",
    "action_rights",
    "required_approvals",
    "compliance_tags",
    "output_schema",
    "expected_artifacts",
    "trace_context",
    "sla",
    "status",
    "confidence",
    "progress",
    "memory_mode",
    "memory_refs",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "task_id":        { "type": "string", "pattern": "^utcp-.+" },
    "workflow_id":    { "type": "string" },
    "version":        { "type": "integer", "minimum": 1 },
    "function": {
      "type": "string",
      "enum": [
        "engineering", "marketing", "product", "hr", "ta", "program",
        "finance", "legal", "support", "design", "data", "cross-functional"
      ]
    },
    "stage":          { "type": "string" },
    "intent":         { "type": "string" },

    "initiator": {
      "type": "object",
      "required": ["user_id", "role"],
      "properties": {
        "user_id": { "type": "string" },
        "role":    { "type": "string" },
        "email":   { "type": "string", "format": "email" }
      },
      "additionalProperties": false
    },

    "actors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent_id", "role"],
        "properties": {
          "agent_id": { "type": "string" },
          "role":     { "type": "string" },
          "regiment": { "type": "string" },
          "rank":     { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "objectives":       { "type": "array", "items": { "type": "string" } },
    "constraints":      { "type": "array", "items": { "type": "string" } },
    "success_criteria": { "type": "array", "items": { "type": "string" } },

    "source_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "ref", "tool"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["document", "ticket", "code", "report", "data", "config", "approval", "message"]
          },
          "ref":      { "type": "string" },
          "tool":     { "type": "string" },
          "title":    { "type": "string" },
          "content":  { "type": "string" },
          "metadata": { "type": "object" }
        },
        "additionalProperties": false
      }
    },

    "tool_scopes": { "type": "array", "items": { "type": "string" } },
    "context":     { "type": "object" },

    "privacy_level": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"]
    },

    "action_rights": { "type": "array", "items": { "type": "string" } },

    "required_approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "threshold", "required"],
        "properties": {
          "role":      { "type": "string" },
          "threshold": { "type": "string", "enum": ["any", "majority", "unanimous"] },
          "required":  { "type": "boolean" },
          "auto_approve_if_confidence_above": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    },

    "compliance_tags":    { "type": "array", "items": { "type": "string" } },
    "output_schema":      { "type": "object" },
    "expected_artifacts": { "type": "array", "items": { "type": "string" } },

    "trace_context": {
      "type": "object",
      "required": ["span_id", "root_id", "depth"],
      "properties": {
        "parent_id": { "type": "string" },
        "span_id":   { "type": "string" },
        "root_id":   { "type": "string" },
        "depth":     { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },

    "sla": {
      "type": "object",
      "required": ["urgency"],
      "properties": {
        "urgency":         { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "deadline":        { "type": "string", "format": "date-time" },
        "max_duration_ms": { "type": "number", "minimum": 0 },
        "max_cost_usd":    { "type": "number", "minimum": 0 },
        "max_tokens":      { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },

    "status": {
      "type": "string",
      "enum": [
        "pending", "planning", "executing", "reviewing",
        "awaiting_approval", "completed", "failed", "cancelled"
      ]
    },

    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "progress":   { "type": "number", "minimum": 0, "maximum": 100 },

    "memory_mode": {
      "type": "string",
      "enum": ["read", "write", "both", "none"]
    },
    "memory_refs": { "type": "array", "items": { "type": "string" } },

    "created_at":   { "type": "string", "format": "date-time" },
    "updated_at":   { "type": "string", "format": "date-time" },
    "started_at":   { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },

    "results": {
      "type": "object",
      "required": ["outputs", "decisions", "agent_traces"],
      "properties": {
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/properties/source_artifacts/items" }
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["topic", "outcome", "confidence", "rationale"],
            "properties": {
              "topic":      { "type": "string" },
              "outcome":    { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "rationale":  { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "agent_traces": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["agent_id", "steps", "tokens_used", "cost_usd", "duration_ms"],
            "properties": {
              "agent_id":    { "type": "string" },
              "steps":       { "type": "integer", "minimum": 0 },
              "tokens_used": { "type": "integer", "minimum": 0 },
              "cost_usd":    { "type": "number", "minimum": 0 },
              "duration_ms": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "quality_score":     { "type": "number", "minimum": 0, "maximum": 1 },
        "human_corrections": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
